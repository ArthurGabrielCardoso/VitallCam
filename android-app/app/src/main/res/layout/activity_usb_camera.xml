<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <com.serenegiant.widget.AspectRatioSurfaceView
        android:id="@+id/cameraSurface"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Botões flutuantes (canto superior esquerdo, igual ao web) -->
    <LinearLayout
        android:id="@+id/topBar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_margin="16dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintLeft_toLeftOf="parent">

        <ImageButton
            android:id="@+id/btnCapture"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:background="@drawable/bg_circle_primary"
            android:src="@drawable/ic_camera"
            android:scaleType="center"
            android:elevation="6dp"
            android:contentDescription="Capturar foto" />

        <ImageButton
            android:id="@+id/btnSave"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:layout_marginStart="16dp"
            android:background="@drawable/bg_circle_secondary"
            android:src="@drawable/ic_save"
            android:scaleType="center"
            android:elevation="6dp"
            android:visibility="gone"
            android:contentDescription="Salvar fotos" />

        <ImageButton
            android:id="@+id/btnCancel"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:layout_marginStart="16dp"
            android:background="@drawable/bg_circle_dark"
            android:src="@drawable/ic_close"
            android:scaleType="center"
            android:elevation="6dp"
            android:contentDescription="Fechar" />
    </LinearLayout>

    <!-- Status (cantinho discreto) -->
    <TextView
        android:id="@+id/statusText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:padding="10dp"
        android:layout_marginStart="16dp"
        android:layout_marginTop="8dp"
        android:background="#80000000"
        android:textColor="#FFFFFF"
        android:textSize="13sp"
        android:text="Conecte a câmera intraoral via cabo OTG"
        app:layout_constraintTop_toBottomOf="@id/topBar"
        app:layout_constraintLeft_toLeftOf="parent" />

    <!-- Painel lateral direito com fotos capturadas (igual ao web) -->
    <LinearLayout
        android:id="@+id/sidePanel"
        android:layout_width="280dp"
        android:layout_height="0dp"
        android:orientation="vertical"
        android:background="@color/vc_panel"
        android:padding="16dp"
        android:elevation="8dp"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintRight_toRightOf="parent">

        <TextView
            android:id="@+id/sideTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="@color/vc_panel_text"
            android:text="Fotos Capturadas (0)"
            android:layout_marginBottom="12dp" />

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:scrollbars="vertical">

            <LinearLayout
                android:id="@+id/thumbsContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />
        </ScrollView>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
